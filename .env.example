# ── Jarvis configuration ──────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.

# Required: your Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which Claude model powers Jarvis's brain. Leave as-is unless you
# have a reason to change it.
ANTHROPIC_MODEL=claude-opus-4-8

# Optional: reasoning effort — low | medium | high.
# "low" is snappiest for voice; "high" is smartest. Default: medium.
JARVIS_EFFORT=medium

# Optional: what Jarvis calls you.
JARVIS_USER_NAME=David

# ── Voice input (speech-to-text) ──────────────────────────────────────
# Powers the microphone and the "Hey Jarvis" wake word. Without this,
# talking is disabled but typing and voice OUTPUT still work.
#
# Uses OpenAI's transcription API by default. Get a key at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: which transcription model. gpt-4o-mini-transcribe is fast and
# cheap; "whisper-1" also works.
STT_MODEL=gpt-4o-mini-transcribe

# Optional: point at any OpenAI-compatible transcription endpoint (e.g. a
# local Whisper server, or Groq). Uses STT_API_KEY if set, else OPENAI_API_KEY.
# STT_BASE_URL=https://api.openai.com/v1
# STT_API_KEY=

# ── Google integration (Calendar + Gmail) ─────────────────────────────
# These are OPTIONAL. Jarvis runs fully without them (reminders, chat, and
# general Q&A all work). Fill these in to unlock live Calendar + Email.
#
# Setup:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project, enable the Google Calendar API and Gmail API.
#   3. Create an OAuth 2.0 Client ID (type: "Desktop app").
#   4. Paste the client ID and secret below.
#   5. The first time you use a calendar/email command, Jarvis will open a
#      browser window to authorize access.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
